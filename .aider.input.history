+- .pill (.green, .yellow, .red, .blue, .gray)
+- .tabbar, .tab, .tab.active
+- .row, .row.center, .divider
+- .exercise, .exercise-name, .exercise-detail, .exercise-note
+- .modal-overlay, .modal, .modal-title, .modal-close, .modal-content
+- .collapsible, .collapsible-header, .collapsible-content
+- .toggle, .toggle.on, .toggle::after
+- .stat-grid, .stat-box, .stat-value, .stat-label
+- .text-sm, .text-xs, .highlight
+- .badge-ok, .badge-warn, .badge-bad
+- .chip, .chip.active
+- .grid-2, .grid-3, .grid-4
+- .month-stats, .month-stat-item, .month-stat-value, .month-stat-label
+- .mini-chart, .bar
+
+Все интерактивные элементы должны иметь min-height 44px для touch-friendly.
+Используй -webkit-tap-highlight-color: transparent для сброса подсветки на мобильных.

